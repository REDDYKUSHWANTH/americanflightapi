<?xml version="1.0" encoding="UTF-8"?>

<mule xmlns:ee="http://www.mulesoft.org/schema/mule/ee/core"
      xmlns="http://www.mulesoft.org/schema/mule/core"
      xmlns:doc="http://www.mulesoft.org/schema/mule/documentation"
      xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:schemaLocation="
      http://www.mulesoft.org/schema/mule/core http://www.mulesoft.org/schema/mule/core/current/mule.xsd
      http://www.mulesoft.org/schema/mule/ee/core http://www.mulesoft.org/schema/mule/ee/core/current/mule-ee.xsd">

    <error-handler name="global-error-handler">

        <!-- BAD REQUEST -->
        <on-error-propagate type="APIKIT:BAD_REQUEST">
            <ee:transform>
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
  code: 400,
  message: "Bad Request",
  description: error.description default "",
  timestamp: now(),
  transactionId: correlationId
}
]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- NOT FOUND -->
        <on-error-propagate type="APIKIT:NOT_FOUND">
            <ee:transform>
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
  code: 404,
  message: "Resource Not Found",
  timestamp: now(),
  transactionId: correlationId
}
]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">404</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- METHOD NOT ALLOWED -->
        <on-error-propagate type="APIKIT:METHOD_NOT_ALLOWED">
            <ee:transform>
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
  code: 405,
  message: "Method Not Allowed",
  timestamp: now(),
  transactionId: correlationId
}
]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">405</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- NOT ACCEPTABLE -->
        <on-error-propagate type="APIKIT:NOT_ACCEPTABLE">
            <ee:transform>
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
  code: 406,
  message: "Not Acceptable",
  timestamp: now(),
  transactionId: correlationId
}
]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">406</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- UNSUPPORTED MEDIA TYPE -->
        <on-error-propagate type="APIKIT:UNSUPPORTED_MEDIA_TYPE">
            <ee:transform>
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
  code: 415,
  message: "Unsupported Media Type",
  timestamp: now(),
  transactionId: correlationId
}
]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">415</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- DATABASE CONNECTIVITY -->
        <on-error-propagate type="DB:CONNECTIVITY">
            <ee:transform>
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
  code: 503,
  message: "Database connection failed",
  timestamp: now(),
  transactionId: correlationId
}
]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">503</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- HTTP CONNECTIVITY -->
        <on-error-propagate type="HTTP:CONNECTIVITY">
            <ee:transform>
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
  code: 503,
  message: "External service unavailable",
  timestamp: now(),
  transactionId: correlationId
}
]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">503</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- DATAWEAVE / EXPRESSION ERROR -->
        <on-error-propagate type="MULE:EXPRESSION">
            <ee:transform>
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
  code: 400,
  message: "Transformation error",
  timestamp: now(),
  transactionId: correlationId
}
]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">400</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

        <!-- DEFAULT ERROR -->
        <on-error-propagate type="ANY">
            <ee:transform>
                <ee:message>
                    <ee:set-payload><![CDATA[
%dw 2.0
output application/json
---
{
  code: 500,
  message: "Internal Server Error",
  timestamp: now(),
  transactionId: correlationId
}
]]></ee:set-payload>
                </ee:message>
                <ee:variables>
                    <ee:set-variable variableName="httpStatus">500</ee:set-variable>
                </ee:variables>
            </ee:transform>
        </on-error-propagate>

    </error-handler>

</mule>